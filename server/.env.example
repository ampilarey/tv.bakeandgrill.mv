# Bake & Grill TV — Environment Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git — it is gitignored.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── Security ─────────────────────────────────────────────────────────────────
# Generate a strong random secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be ≥ 32 characters.
JWT_SECRET=REPLACE_WITH_A_RANDOM_64_CHAR_HEX_STRING

# ── MySQL Database ────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_mysql_username
DB_PASSWORD=your_mysql_password
DB_NAME=your_database_name

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins in production.
CORS_ORIGINS=https://tv.bakeandgrill.mv

# ── Admin Bootstrap (opt-in only) ────────────────────────────────────────────
# Leave ALLOW_DEFAULT_ADMIN unset (or false) in production once the first
# admin exists. Use  node scripts/create-admin.js  instead.
ALLOW_DEFAULT_ADMIN=false
DEFAULT_ADMIN_EMAIL=admin@yourdomain.com
DEFAULT_ADMIN_PASSWORD=ChangeThisPassword123!

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Bake and Grill TV
MAX_PLAYLISTS_PER_USER=10
SESSION_TIMEOUT_DAYS=7

# ── File Uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# ── Rate Limiting (optional overrides) ───────────────────────────────────────
# API_RATE_LIMIT=600
# AUTH_RATE_LIMIT=100
