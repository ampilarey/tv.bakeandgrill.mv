# Bake & Grill TV - Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to Git!

# Server Configuration
PORT=4000
NODE_ENV=production

# Security - CHANGE THIS TO A RANDOM STRING!
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-to-random-string-minimum-32-characters

# MySQL Database Configuration
# Create database and user in cPanel → MySQL Databases
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_mysql_username
DB_PASSWORD=your_mysql_password
DB_NAME=your_database_name

# Default Admin Account
# These credentials are used to create the first admin user
# IMPORTANT: Change the password after first login!
DEFAULT_ADMIN_EMAIL=admin@yourdomain.com
DEFAULT_ADMIN_PASSWORD=ChangeThisPassword123!

# Application Settings
APP_NAME=Bake and Grill TV
MAX_PLAYLISTS_PER_USER=10
SESSION_TIMEOUT_DAYS=7

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# Optional: Custom PWA Icon
# PWA_ICON_PATH=/path/to/custom/icon.png
