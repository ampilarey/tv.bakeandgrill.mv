# Bake & Grill TV - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ===========================================
# DATABASE CONFIGURATION (MySQL)
# ===========================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=bakegrill_tv

# ===========================================
# SECURITY (CRITICAL!)
# ===========================================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-64-character-random-hex-string-here-change-this-immediately

# ===========================================
# SERVER CONFIGURATION
# ===========================================
PORT=4000
NODE_ENV=development

# ===========================================
# DEFAULT ADMIN CREDENTIALS
# ===========================================
# ⚠️ CHANGE THESE AFTER FIRST LOGIN!
DEFAULT_ADMIN_EMAIL=admin@bakegrill.com
DEFAULT_ADMIN_PASSWORD=BakeGrill2025!

# ===========================================
# APPLICATION SETTINGS (Optional)
# ===========================================
APP_NAME=Bake and Grill TV
SESSION_TIMEOUT_DAYS=7
MAX_PLAYLISTS_PER_USER=10

# ===========================================
# NOTES
# ===========================================
# 1. Never commit the actual .env file to git
# 2. Generate a strong JWT_SECRET before production
# 3. Change default admin password immediately
# 4. Use HTTPS in production (SSL certificate)
# 5. Setup regular database backups
